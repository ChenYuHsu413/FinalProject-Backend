# AI SERVO PLATFORM backend — environment template.
# Copy to `.env` (chmod 600 on the VM) and fill real values. Never commit `.env`.

# Application ------------------------------------------------------------------
APP_ENV=dev                       # dev | prod
API_VERSION=0.1.0
SCHEMA_VERSION=1.0

# Trust boundary --------------------------------------------------------------
# Shared secret between the Flask BFF and this API. Generate with:
#   openssl rand -hex 32
# The API rejects any /api/v1/* request whose Authorization bearer != this value.
SERVICE_TOKEN=replace-me-with-openssl-rand-hex-32

# Engine data (file-backed ML pipeline outputs) -------------------------------
# Single root for models.jsonl, L3 rankings, shadow/diagnosis JSON, fallback db…
ENGINE_DATA_DIR=/srv/data/engine

# PostgreSQL (governance data) — used from batch 2 onward ---------------------
POSTGRES_USER=aiservo
POSTGRES_PASSWORD=changeme
POSTGRES_DB=aiservo
DATABASE_URL=postgresql+asyncpg://aiservo:changeme@postgres:5432/aiservo

# Redis (events) — used from batch 3 onward -----------------------------------
REDIS_URL=redis://redis:6379/0

# Mock simulator (engine layer) — used from batch 3 onward --------------------
MOCK_MODE=true

# Model service (batch 8) — external inference --------------------------------
# SEAM B: swap the URL when the model team delivers. "mock" keeps the built-in
# deterministic generator (no outbound calls) — this is the safe default for CI.
MODEL_SOURCE=mock                  # mock | http
MODEL_SERVICE_URL=                 # e.g. https://icefeather-aifinalproject.hf.space
MODEL_SERVICE_TIMEOUT_S=3
MODEL_CACHE_TTL_S=5
